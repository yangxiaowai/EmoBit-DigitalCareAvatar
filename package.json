{
  "name": "yihutongxing-ai-smart-elder-care-system",
  "description": "忆护同行——面向老年智能陪伴、健康监测与风险预警的 AI 智慧照护系统",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tts": "conda run -n emobit python scripts/edge_tts_server.py",
    "dev:all": "npm-run-all -p dev dev:tts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:functional": "vitest run -c vitest.functional.config.ts --passWithNoTests",
    "test:functional:live": "VITEST_REAL_SERVICES=1 vitest run -c vitest.functional.config.ts tests/real --passWithNoTests",
    "test:asr:wer-ser:template": "python3 scripts/evaluate_asr_wer_ser.py --audio-root val/Audio_files --template-out docs/test-artifacts/asr_eval_manifest.template.csv --limit 50",
    "test:asr:wer-ser": "python3 scripts/evaluate_asr_wer_ser.py --manifest docs/test-artifacts/asr_eval_manifest.template.csv --funasr-url ws://127.0.0.1:10095",
    "test:system": "vitest run -c vitest.system.config.ts --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "openclaw:bridge": "node openclaw/bridge/server.mjs",
    "data-server:start": "node backend/data-server/server.mjs",
    "openclaw:cron:bootstrap": "node openclaw/scripts/bootstrap-cron.mjs"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "dotenv": "^17.2.2",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "three": "0.160.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "@types/dom-speech-recognition": "^0.0.7",
    "@types/node": "^22.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^26.1.0",
    "msw": "^2.11.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4",
    "whatwg-fetch": "^3.6.20"
  }
}
